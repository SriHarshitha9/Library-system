<!DOCTYPE html>
<html>
<head>
  <title>Flowchart – LMS</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="nav">
  <a href="javascript:history.back()">← Back</a>
</div>

<div class="container" style="text-align:center">
  <h2>Application Flowchart</h2>
  <p style="color:#555;margin-bottom:20px;font-size:14px">Overview of the Library Management System flow</p>

  <svg viewBox="0 0 680 620" width="100%" xmlns="http://www.w3.org/2000/svg" style="font-family:Segoe UI,sans-serif">
    <defs>
      <marker id="arr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="#2c3e50" stroke-width="1.5" stroke-linecap="round"/>
      </marker>
    </defs>

    <!-- Login -->
    <rect x="250" y="20" width="140" height="44" rx="8" fill="#2980b9" stroke="#1a5276" stroke-width="0.5"/>
    <text x="320" y="46" text-anchor="middle" fill="#fff" font-size="14" font-weight="500">Login</text>

    <!-- Arrow down -->
    <line x1="320" y1="64" x2="320" y2="98" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>

    <!-- Role Decision -->
    <polygon points="320,100 420,136 320,172 220,136" fill="#f39c12" stroke="#b7770d" stroke-width="0.5"/>
    <text x="320" y="140" text-anchor="middle" fill="#fff" font-size="13" font-weight="500">Role?</text>

    <!-- Admin branch -->
    <line x1="220" y1="136" x2="100" y2="136" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <text x="158" y="128" text-anchor="middle" fill="#555" font-size="12">Admin</text>

    <rect x="20" y="110" width="80" height="44" rx="8" fill="#1abc9c" stroke="#148a74" stroke-width="0.5"/>
    <text x="60" y="136" text-anchor="middle" fill="#fff" font-size="12" font-weight="500">Maintenance</text>

    <!-- Maintenance sub-items -->
    <line x1="60" y1="154" x2="60" y2="185" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="20" y="185" width="80" height="34" rx="6" fill="#eafaf1" stroke="#1abc9c" stroke-width="0.5"/>
    <text x="60" y="206" text-anchor="middle" fill="#1a6040" font-size="11">Add Book</text>

    <line x1="60" y1="219" x2="60" y2="245" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="20" y="245" width="80" height="34" rx="6" fill="#eafaf1" stroke="#1abc9c" stroke-width="0.5"/>
    <text x="60" y="266" text-anchor="middle" fill="#1a6040" font-size="11">Update Book</text>

    <line x1="60" y1="279" x2="60" y2="305" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="20" y="305" width="80" height="34" rx="6" fill="#eafaf1" stroke="#1abc9c" stroke-width="0.5"/>
    <text x="60" y="326" text-anchor="middle" fill="#1a6040" font-size="11">Membership</text>

    <!-- User branch -->
    <line x1="420" y1="136" x2="550" y2="136" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <text x="483" y="128" text-anchor="middle" fill="#555" font-size="12">User</text>

    <!-- Reports -->
    <rect x="555" y="110" width="90" height="44" rx="8" fill="#9b59b6" stroke="#6c3483" stroke-width="0.5"/>
    <text x="600" y="136" text-anchor="middle" fill="#fff" font-size="12" font-weight="500">Reports</text>

    <!-- Arrow down to transactions -->
    <line x1="320" y1="172" x2="320" y2="215" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>

    <!-- Transactions box -->
    <rect x="220" y="215" width="200" height="44" rx="8" fill="#e74c3c" stroke="#a93226" stroke-width="0.5"/>
    <text x="320" y="241" text-anchor="middle" fill="#fff" font-size="14" font-weight="500">Transactions</text>

    <!-- Issue -->
    <line x1="260" y1="259" x2="200" y2="305" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="140" y="305" width="100" height="44" rx="8" fill="#fadbd8" stroke="#e74c3c" stroke-width="0.5"/>
    <text x="190" y="325" text-anchor="middle" fill="#922b21" font-size="12" font-weight="500">Issue Book</text>
    <text x="190" y="341" text-anchor="middle" fill="#922b21" font-size="11">+ Validate</text>

    <!-- Return -->
    <line x1="380" y1="259" x2="440" y2="305" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="390" y="305" width="100" height="44" rx="8" fill="#fadbd8" stroke="#e74c3c" stroke-width="0.5"/>
    <text x="440" y="325" text-anchor="middle" fill="#922b21" font-size="12" font-weight="500">Return Book</text>
    <text x="440" y="341" text-anchor="middle" fill="#922b21" font-size="11">+ Serial No</text>

    <!-- Arrow to Fine Pay -->
    <line x1="440" y1="349" x2="440" y2="395" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <rect x="370" y="395" width="140" height="44" rx="8" fill="#fef9e7" stroke="#f0c040" stroke-width="0.5"/>
    <text x="440" y="415" text-anchor="middle" fill="#7d6608" font-size="12" font-weight="500">Fine Pay</text>
    <text x="440" y="431" text-anchor="middle" fill="#7d6608" font-size="11">Checkbox confirm</text>

    <!-- Complete -->
    <line x1="440" y1="439" x2="440" y2="480" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>
    <line x1="190" y1="349" x2="190" y2="480" stroke="#2c3e50" stroke-width="1"/>
    <line x1="190" y1="480" x2="440" y2="480" stroke="#2c3e50" stroke-width="1" marker-end="url(#arr)"/>

    <rect x="280" y="480" width="160" height="44" rx="8" fill="#2c3e50" stroke="#1a252f" stroke-width="0.5"/>
    <text x="360" y="506" text-anchor="middle" fill="#fff" font-size="14" font-weight="500">Transaction Done</text>

    <!-- Reports connects too -->
    <line x1="600" y1="154" x2="600" y2="230" stroke="#9b59b6" stroke-width="1" stroke-dasharray="5 4" marker-end="url(#arr)"/>
    <text x="620" y="200" fill="#555" font-size="11">view</text>

    <line x1="600" y1="230" x2="422" y2="237" stroke="#9b59b6" stroke-width="1" stroke-dasharray="5 4" marker-end="url(#arr)"/>

  </svg>
</div>

</body>
</html>
